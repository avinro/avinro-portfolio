# ─────────────────────────────────────────────
# PostHog analytics (PRO-22)
# Privacy-first, cookieless. No cookies required for basic page view tracking.
# Obtain your project API key from: https://eu.posthog.com/settings/project
# Leave NEXT_PUBLIC_POSTHOG_KEY empty to disable analytics entirely.
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
# EU region (GDPR-friendly default). Switch to https://us.i.posthog.com if needed.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────
GEMINI_API_KEY=
# Read ONLY from server modules (lib/ai/*). Set to "true" to enable AI calls.
# Any value other than "true" (including empty) disables all AI calls gracefully.
NEXT_PUBLIC_AI_ENABLED=
